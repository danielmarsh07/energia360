# Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/energia360"

# JWT
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"

# Upload de arquivos
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN="http://localhost:5173"

# Anthropic / Claude AI
ANTHROPIC_API_KEY="sk-ant-..."
